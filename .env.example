# SEAM 环境变量配置示例
# 复制为 .env 文件并填入你的实际配置

# ==================== AI 提供商配置 ====================

# 选择 AI 提供商: openai | anthropic | local
SEAM_AI_PROVIDER=openai

# OpenAI 配置 (当 provider=openai 时使用)
OPENAI_API_KEY=sk-your-openai-api-key-here
SEAM_AI_MODEL=gpt-4

# 或 Anthropic 配置 (当 provider=anthropic 时使用)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# SEAM_AI_MODEL=claude-3-sonnet-20240229

# 或本地模型配置 (当 provider=local 时使用，如 Ollama)
# SEAM_AI_BASE_URL=http://localhost:11434
# SEAM_AI_MODEL=llama2

# AI 调用超时时间（毫秒）
SEAM_AI_TIMEOUT=60000

# ==================== 网格配置 ====================

# 创世智能体配置（格式: 类型:数量,类型:数量...）
# O=orchestrator, R=researcher, E=executor, V=validator, EV=evolver
SEAM_AGENTS=O:1,R:2,E:3,V:1

# 是否启用进化功能
SEAM_EVOLUTION_ENABLED=true

# 进化间隔（分钟）
SEAM_EVOLUTION_INTERVAL=360

# ==================== HTTP 服务器配置 ====================

# 服务器端口
SEAM_PORT=18789

# 服务器地址
SEAM_HOST=0.0.0.0

# API 鉴权密钥（可选，设置后需要提供 Bearer Token）
# SEAM_API_KEY=your-secret-api-key
