    "openclaw-extension",
    "agent",
    "mesh",
    "evolution"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.3",
    "openclaw": "file:../openclaw",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
